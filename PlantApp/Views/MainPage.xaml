<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:selectors="clr-namespace:PlantApp.Selectors"
             xmlns:views="clr-namespace:PlantApp.Views"
             x:Class="PlantApp.Views.MainPage"
             Title="Planty">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Border">
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
                <Setter Property="Margin" Value="0,0,0,0" />
            </Style>    

            <!-- TEMPLATE: РАСТЕНИЕ -->
            <DataTemplate x:Key="PlantTemplate">
                <Border
                    WidthRequest="140"
                    HeightRequest="170"
                    Margin="6,0"
                    StrokeThickness="0"
                    BackgroundColor="Transparent">


                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="2,2"
                                Radius="5"
                                Opacity="0.1" />
                    </Border.Shadow>

                    <Grid>

                        <!-- КАРТИНКА -->
                        <Border StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape> 
                            <Image
                                Source="{Binding PlantImage}"
                                Aspect="AspectFill"/>
                        </Border>

                        <!-- ЗАТЕМНЕНИЕ -->
                        <Border 
                            BackgroundColor="Black"
                            Opacity="0.1"> 

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            
                        </Border>

                        <!-- НАЗВАНИЕ -->
                        <Label 
                            Text="{Binding NamePlant}"
                            FontSize="16"
                            FontAttributes="None"
                            FontFamily="Montserrat"
                            TextColor="White"
                            Margin="10"
                            VerticalOptions="End"
                            HorizontalOptions="Center"
                            MaxLines="2"/>

                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                      Path=BindingContext.OpenPlantDetailsCommand}"
                            CommandParameter="{Binding .}" />
                    </Border.GestureRecognizers>

                </Border>
            </DataTemplate>

            <!-- TEMPLATE: СМОТРЕТЬ ВСЕ -->
            <DataTemplate x:Key="SeeAllTemplate">
                <Border
                    WidthRequest="140"
                    HeightRequest="170"
                    Margin="6,0"
                    StrokeThickness="0">
                    <Grid>

                        <!-- ФОН -->
                        <Border BackgroundColor="LightGreen">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                        </Border>

                        <!-- ТЕКСТ -->
                        <VerticalStackLayout
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            Spacing="4">

                            <Label Text="Все"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"/>

                            <Label Text="растения"
                               FontSize="12"
                               TextColor="White"
                               HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>

                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                      Path=BindingContext.OpenAllPlantsCommand}" />
                    </Border.GestureRecognizers>

                </Border>
            </DataTemplate>

            <!-- SELECTOR -->
            <selectors:PopularTemplateSelector
                x:Key="PopularTemplateSelector"
                PlantTemplate="{StaticResource PlantTemplate}"
                SeeAllTemplate="{StaticResource SeeAllTemplate}" />

        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- ОСНОВНОЙ GRID -->
    <Grid Background="#F0EEE9">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- SCROLLABLE CONTENT -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="30" Spacing="20">

                <Grid ColumnDefinitions="*"
                      RowDefinitions="Auto">

                    <Image Source="planty_logo_final.png"
                           Grid.Column="1"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" 
                           HeightRequest="80"/>
                </Grid>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- GPT -->
                    <Border Margin="8"
                        BackgroundColor="White"
                        Padding="15"
                        StrokeShape="RoundRectangle 20">

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                Offset="5,5"
                                Radius="5"
                                Opacity="0.1" />
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OnGPTCommand}"/>
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="8"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

                            <Image Source="question.png"    
                                HeightRequest="40"/>

                            <Label Text="Yandex AI"
                                    FontSize="14" 
                                    FontFamily="Montserrat"
                                    TextColor="#2E7D32"
                                    HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Encyclopedia -->
                    <Border Margin="8"
                            Grid.Row="0"
                            Grid.Column="1" 
                            BackgroundColor="White"
                            Padding="15"
                            StrokeShape="RoundRectangle 20">

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                Offset="5,5"
                                Radius="5"
                                Opacity="0.1" />
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OnEncyclopediaCommand}"/>
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="8"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image Source="encyclopedia.png" 
                                   HeightRequest="40"/>

                            <Label Text="Энциклопедия"
                                    FontSize="14" 
                                    FontFamily="Montserrat"
                                    TextColor="#2E7D32"
                                    HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Swap -->
                    <Border Margin="8"
                            Grid.Row="1"
                            Grid.Column="0" 
                            BackgroundColor="White"
                            Padding="15"
                            StrokeShape="RoundRectangle 20">

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                Offset="5,5"
                                Radius="5"
                                Opacity="0.1" />
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OnSwapCommand}"/>
                        </Border.GestureRecognizers>


                        <VerticalStackLayout Spacing="8"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image Source="swap_logo.png" 
                                   HeightRequest="40"/>

                            <Label Text="Своп-маркет"
                                    FontSize="14" 
                                    FontFamily="Montserrat"
                                    TextColor="#2E7D32"
                                    HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Favorites -->
                    <Border Margin="8"
                            Grid.Row="1"
                            Grid.Column="1"
                            BackgroundColor="White"
                            Padding="15"
                            StrokeShape="RoundRectangle 20" >

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                Offset="5,5"
                                Radius="5"
                                Opacity="0.1" />
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OnFavoritesCommand}"/>
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="8"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image Source="favorite.png" 
                                   HeightRequest="40"/>

                            <Label Text="Избранное"
                                    FontSize="14" 
                                    FontFamily="Montserrat"
                                    TextColor="#2E7D32"
                                    HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Search -->
                <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 25"
                    Padding="10"
                    Margin="0,10">
                    <VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto,*">

                            <Image Source="search.png"
                                HeightRequest="20"
                                Margin="5"/>

                            <Entry Grid.Column="1"
                                    Placeholder="Поиск растений"
                                    Text="{Binding SearchPlant}"
                                    FontSize="14"
                                    TextColor="Black"
                                    PlaceholderColor="Gray"
                                    BackgroundColor="Transparent"/>

                        </Grid>

                        <CollectionView ItemsSource="{Binding SearchResults}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border 
                                        Padding="10"
                                        Margin="5"
                                        BackgroundColor="White">

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource 
                                                    AncestorType={x:Type ContentPage}}, 
                                                    Path=BindingContext.OpenPlantDetailsCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*">

                                            <Border 
                                                StrokeThickness="0" 
                                                Grid.Column="0">

                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="15"/>
                                                </Border.StrokeShape>

                                                <Image
                                                    Source="{Binding PlantImage}"
                                                    HeightRequest="60"
                                                    WidthRequest="60"
                                                    Aspect="AspectFill"/>
                                            </Border>

                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding NamePlant}"
                                                FontSize="24"
                                                TextColor="Black"
                                                VerticalOptions="Center"
                                                Margin="15,0,0,0"/>

                                        </Grid>

                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>

                </Border>

                <Label Text="Популярные растения"
                       FontSize="24"
                       FontAttributes="None"
                       FontFamily="Montserrat"
                       Margin="0, 5, 0, 0"
                       TextColor="Black"/>

                <CollectionView ItemsSource="{Binding PopularPreview}"
                    ItemTemplate="{StaticResource PopularTemplateSelector}"
                    ItemsLayout="HorizontalList"
                    HeightRequest="180"
                    HorizontalScrollBarVisibility="Never" 
                    ItemSizingStrategy="MeasureFirstItem">
                </CollectionView>



            </VerticalStackLayout>

        </ScrollView>

        <!-- НИЖНИЙ БАР -->
        <views:BottomBarView Grid.Row="1"/>

    </Grid>

</ContentPage>