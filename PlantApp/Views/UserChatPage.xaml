<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="ThisPage"
             x:Class="PlantApp.Views.UserChatPage"
             Title="Чат"
             BackgroundColor="#F0EEE9">

    <Grid RowDefinitions="*,Auto">

        <CollectionView ItemsSource="{Binding Messages}"
                        Margin="10"
                        ItemsUpdatingScrollMode="KeepLastItemInView">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Grid>

                        <Border x:Name="MessageBorder"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Margin="5">

                            <VerticalStackLayout Spacing="4">

                                <Label Text="{Binding Content}"
                                       TextColor="Black"/>

                                <Label Text="{Binding CreatedAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="Gray"
                                       HorizontalOptions="End"/>

                            </VerticalStackLayout>

                        </Border>

                        <!-- ВОТ ТУТ ПРАВИЛЬНО -->
                        <Grid.Triggers>
                            
                            <!-- МОИ -->
                            <DataTrigger TargetType="Grid" Binding="{Binding IsMine}" Value="True">
                                <Setter TargetName="MessageBorder"
                                    Property="BackgroundColor"
                                    Value="#367900"/>
                                <Setter Property="HorizontalOptions"
                                    Value="End"/>
                            </DataTrigger>

                            <!-- ЧУЖИЕ -->
                            <DataTrigger TargetType="Grid"
                                         Binding="{Binding SenderId}"
                                         Value="-1">
                                <Setter TargetName="MessageBorder"
                                        Property="BackgroundColor"
                                        Value="White"/>
                                <Setter Property="HorizontalOptions"
                                        Value="Start"/>
                            </DataTrigger>

                        </Grid.Triggers>

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Grid Grid.Row="1"
              Padding="10"
              ColumnDefinitions="*,Auto"
              BackgroundColor="#F0EEE9">

            <Entry Grid.Column="0"
                   Text="{Binding MessageText}"
                   Placeholder="Сообщение..."
                   ReturnType="Send"
                   Completed="OnEnterPressed"/>

            <Button Grid.Column="1"
                    Text="➤"
                    Command="{Binding SendCommand}"
                    BackgroundColor="#367900"
                    TextColor="White"
                    CornerRadius="20"
                    WidthRequest="50"/>

        </Grid>

    </Grid>

</ContentPage>