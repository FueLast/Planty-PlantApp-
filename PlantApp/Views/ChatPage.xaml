<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:PlantApp.Data"
             x:Class="PlantApp.Views.ChatPage"
             x:Name="ChatPageRoot"
             Title="Chat"
             Background="#F0EEE9">

    <Grid RowDefinitions="*,Auto">

        <!-- список сообщений -->
        <CollectionView ItemsSource="{Binding Messages}"
                        ItemsUpdatingScrollMode="KeepLastItemInView"
                        Margin="10">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:ChatMessage">
 
                    <Grid>

                        <Border Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Margin="5">

                            <VerticalStackLayout Spacing="4">

                                <!-- БАННЕР СО SWAP PAGE -->
                                <Border Padding="8"
                                        BackgroundColor="#E8F5E9"
                                        StrokeShape="RoundRectangle 15"
                                        IsVisible="False">

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding MessageType}"
                                                     Value="plant">
                                            <Setter Property="IsVisible" Value="True"/>
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid ColumnDefinitions="60,*">

                                        <Image Source="{Binding PlantImage}"
                                               HeightRequest="60"
                                               WidthRequest="60"/>

                                        <StackLayout Grid.Column="1">
                                            <Label Text="Предложен обмен 🌿"
                                                   FontAttributes="Bold"/>
                                            <Label Text="{Binding PlantName}" />
                                        </StackLayout>

                                    </Grid>

                                </Border>

                                <!-- ТЕКСТ -->
                                <Label Text="{Binding Content}"
                                       TextColor="Black">

                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding MessageType}"
                                                     Value="plant">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </DataTrigger>
                                    </Label.Triggers>

                                </Label>

                                <!-- время -->
                                <Label Text="{Binding CreatedAt, StringFormat='{0:HH:mm}'}"
                                       FontSize="10"
                                       TextColor="Gray"
                                       HorizontalOptions="End"/>

                            </VerticalStackLayout>

                        </Border>

                        <!-- стили сообщений -->
                        <Grid.Triggers>

                            <!-- пользователь -->
                            <DataTrigger TargetType="Grid"
                                         Binding="{Binding Role}"
                                         Value="user">
                                <Setter TargetName="Border"
                                        Property="BackgroundColor"
                                        Value="#367900"/>
                                <Setter Property="HorizontalOptions"
                                        Value="End"/>
                            </DataTrigger>

                            <!-- бот -->
                            <DataTrigger TargetType="Grid"
                                         Binding="{Binding Role}"
                                         Value="assistant">
                                <Setter TargetName="Border"
                                        Property="BackgroundColor"
                                        Value="White"/>
                                <Setter Property="HorizontalOptions"
                                        Value="Start"/>
                            </DataTrigger>

                        </Grid.Triggers>

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- нижняя панель -->
        <Grid Grid.Row="1"
              Padding="10"
              ColumnDefinitions="*,Auto"
              BackgroundColor="#F0EEE9">

            <!-- поле ввода -->
            <Entry Grid.Column="0"
                   Text="{Binding MessageText}"
                   Placeholder="Напиши сообщение..."
                   ReturnType="Send"
                   Completed="OnEnterPressed"/>

            <!-- кнопка -->
            <Button Grid.Column="1"
                    Text="➤"
                    Command="{Binding SendCommand}"
                    BackgroundColor="#367900"
                    TextColor="White"
                    CornerRadius="20"
                    WidthRequest="50"/>

        </Grid>

    </Grid>
</ContentPage>