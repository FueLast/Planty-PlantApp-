<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PlantApp.Views.ProfilePage"
    Background="#F0EEE9">

    <ScrollView>

        <!-- ОСНОВНАЯ СТРУКТУРА -->
        <Grid
            Margin="15"
            RowDefinitions="Auto,Auto,Auto"
            RowSpacing="20">

            <!-- ================== ВЕРХНИЙ БЛОК ================== -->
            <Border
                Grid.Row="0"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 30">
    
                <Grid IsClippedToBounds="True">

                    <BoxView Color="White"/>

                    <Image
                        Source="background_listik_profile.png"
                        Opacity="0.15"
                        Aspect="AspectFill" />

                    <Grid
                        Padding="20"
                        ColumnDefinitions="Auto, *"
                        ColumnSpacing="20">

                        <!-- Аватар -->
                        <Border 
                            HorizontalOptions="Start"
                            VerticalOptions="Center"
                            WidthRequest="80"
                            HeightRequest="80"
                            Stroke="#367900"
                            StrokeThickness="3"
                            StrokeShape="RoundRectangle 150"
                            Background="White">

                            <Image Source="{Binding Profile, Converter={StaticResource AvatarHelper}}"/>
                        </Border>
                        
                        <ImageButton
                            Grid.Column="1"
                            Background="Transparent"
                            Source="settings.png"
                            WidthRequest="28"
                            HeightRequest="28"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Command="{Binding OpenEditProfileCommand}"/>
                        <!-- Правая часть -->
                        <StackLayout 
                            Grid.Column="1"
                            Spacing="10"
                            HorizontalOptions="End"
                            VerticalOptions="Center">

                            <Label
                                Text="{Binding Profile.UserName}"
                                FontSize="24"
                                TextColor="Black"/>

                            <Label
                                Text="{Binding Profile.City, StringFormat='Город: {0}'}"
                                FontSize="16"
                                TextColor="Gray"/>

                            <Label
                                Text="{Binding Profile.Age, StringFormat='Возраст: {0}'}"
                                FontSize="16"
                                TextColor="Gray"/>

                            <Border
                                Stroke="#367900"
                                StrokeShape="RoundRectangle 20"
                                Background="#F0EEE9">

                                <Editor
                                    Placeholder="Опишите чем вам нравится заниматься"
                                    TextColor="Black"
                                    PlaceholderColor="Gray"
                                    AutoSize="TextChanges"/>

                            </Border>

                        </StackLayout>
                    </Grid>

                </Grid>
            </Border>

            <!-- ================== ДВА НИЖНИХ БЛОКА ================== -->
            <Grid
                Grid.Row="1"
                ColumnDefinitions="2*,*"
                ColumnSpacing="15">

                <!-- МОИ РАСТЕНИЯ -->
                <Border
                    Stroke="#367900"
                    StrokeShape="RoundRectangle 25"
                    Background="White"
                    Padding="15">

                    <Grid RowDefinitions="Auto,*">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label
                                Text="Мои растения" 
                                FontSize="18"
                                TextColor="Black"/>

                            <Button
                                Grid.Column="1"
                                Text="+"
                                WidthRequest="35"
                                HeightRequest="35"
                                Command="{Binding AddPlantCommand}"
                                BackgroundColor="#367900"
                                Margin="0, 0, 0, 10"/>
                        </Grid>

                        <!-- список растений -->
                        <CollectionView
                            Grid.Row="1"
                            ItemsSource="{Binding UserPlants}">

                            <CollectionView.ItemTemplate>

                                <DataTemplate>

                                    <Border 
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 15"
                                        Padding="10"
                                        Margin="0,5">

                                        <Grid ColumnDefinitions="60,*">

                                            <Border StrokeThickness="0" 
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="15"/>
                                                </Border.StrokeShape>
                                                <Image
                                                    Source="{Binding ImagePath}"
                                                    HeightRequest="60"
                                                    WidthRequest="60"
                                                    Aspect="AspectFill"/>
                                            </Border>

                                            <StackLayout Grid.Column="1">

                                                <Label
                                                    Text="{Binding CustomName}"
                                                    FontAttributes="Bold"
                                                    Margin="10, 0, 0, 0"/>

                                                <Label
                                                    Text="{Binding PlantName}"
                                                    FontSize="12"
                                                    Margin="10, 0, 0, 0"/>

                                                <Label
                                                    Text="{Binding LastWateredText}"
                                                    FontSize="11"
                                                    TextColor="Gray"
                                                    Margin="10, 0, 0, 0"/>

                                            </StackLayout>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </Grid>

                </Border>


                <!-- ДРУЗЬЯ -->
                <Border
                     Grid.Column="1"
                     Stroke="#367900"
                     StrokeShape="RoundRectangle 30"
                     Background="White"
                     Padding="10">



                    <Grid RowDefinitions="Auto,*">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label
                            Text="Друзья"
                            FontSize="18"
                            TextColor="Black"/>

                            <Button
                                 Grid.Column="1"
                                 Text="+"
                                 WidthRequest="35"
                                 HeightRequest="35"
                                 Command="{Binding OpenAddFriendCommand}"
                                 BackgroundColor="#367900"/>
                        </Grid>

                        <CollectionView
                            Grid.Row="1"
                            ItemsSource="{Binding Friends}"
                            SelectionMode="Single"
                            SelectionChanged="OnFriendSelected">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border
                                        Padding="8"
                                        Margin="0,5"
                                        StrokeThickness="0">

                                        <Grid ColumnDefinitions="40,*">

                                            <Border
                                                StrokeShape="150" 
                                                Stroke="Transparent">
                                                <Image
                                                    Source="{Binding Profile, 
                                                    Converter={StaticResource AvatarHelper}}"
                                                    HeightRequest="40"
                                                    WidthRequest="40"/>
                                            </Border>
                                            
                                            <StackLayout Grid.Column="1">

                                                <Label
                                                    Text="{Binding Login}"
                                                    FontAttributes="Bold"/>
                                                
                                                <Label
                                                    Text="{Binding Profile.City}"
                                                    FontSize="12"
                                                    TextColor="Gray"/>

                                            </StackLayout>

                                        </Grid>

                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </Grid>

                </Border>
            </Grid> 

        </Grid>

    </ScrollView>

</ContentPage>   