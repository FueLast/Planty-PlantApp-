<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="PlantApp.Views.Popups.CreateSwapOfferPopup"
    BackgroundColor="#F0EEE9">

    <!-- затемнение фона -->
    <Grid>

        <!-- CARD -->
        <Border
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 25"
            Padding="20"
            WidthRequest="340"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Shadow="0,10,25,#40000000">

            <VerticalStackLayout Spacing="16">

                <!-- HEADER -->
                <Label
                    Text="Новый оффер"
                    FontFamily="Montserrat"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="#1E1E1E"/>

                <!-- IMAGE BLOCK -->
                <Border
                    HeightRequest="180"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="#F3F3F3">

                    <Grid>

                        <!-- IMAGE -->
                        <Image
                            Source="{Binding ImagePreview}"
                            Aspect="AspectFill"
                            IsVisible="{Binding HasImage}"/>

                        <!-- SKELETON -->
                        <VerticalStackLayout
                            IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Spacing="4">

                            <Label
                                Text="📷"
                                FontSize="36"
                                HorizontalOptions="Center"
                                TextColor="#999"/>

                            <Label
                                Text="Добавить фото"
                                FontSize="12"
                                TextColor="#888"/>
                        </VerticalStackLayout>

                        <!-- CLICK AREA -->
                        <Button
                            Command="{Binding PickImageCommand}"
                            BackgroundColor="Transparent"/>
                    </Grid>
                </Border>

                <!-- ВЫБОР РАСТЕНИЯ -->
                <VerticalStackLayout Spacing="6">

                    <Label
                        Text="Ваше растение"
                        FontFamily="Montserrat" 
                        FontSize="13"
                        TextColor="#777"/>

                    <Border
                        Stroke="#E0E0E0"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">

                        <Picker
                            Title="Выберите растение"
                            FontFamily="Montserrat"
                            FontSize="14"
                            FontAttributes="Bold"
                            ItemsSource="{Binding Plants}"
                            ItemDisplayBinding="{Binding NamePlant}"
                            SelectedItem="{Binding SelectedPlant}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- ОПИСАНИЕ -->
                <VerticalStackLayout Spacing="6">

                    <Label
                        Text="Что хотите получить"
                        FontFamily="Montserrat"
                        FontSize="13"
                        TextColor="#777"/>

                    <Border
                        Stroke="#E0E0E0"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">

                        <Entry
                            Placeholder="Например: монстера, фикус..."
                            Text="{Binding DesiredText}"
                            FontFamily="Montserrat"
                            BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <!-- BUTTON -->
                <Button
                    Text="Создать оффер"
                    FontFamily="Montserrat"
                    Command="{Binding CreateCommand}"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="16"
                    HeightRequest="48"
                    FontAttributes="Bold"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</toolkit:Popup>