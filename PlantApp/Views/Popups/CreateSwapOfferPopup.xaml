<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="PlantApp.Views.Popups.CreateSwapOfferPopup"
    BackgroundColor="#F0EEE9">

    <!-- затемнение фона -->
    <Grid>

        <!-- CARD -->
        <Border
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 25"
            Padding="20"
            WidthRequest="340"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Shadow="0,10,25,#40000000">

            <VerticalStackLayout
                Padding="20"
                Spacing="18"
                BackgroundColor="White"
                WidthRequest="340">

                <Label
                    Text="Новый оффер"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"/>

                <!-- IMAGE -->
                <Border
                    HeightRequest="180"
                    Stroke="#E0E0E0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="#F7F7F7">

                    <Grid>

                        <Image
                            Source="{Binding ImagePreview}"
                            Aspect="AspectFill"
                            IsVisible="{Binding HasImage}"/>

                        <VerticalStackLayout
                            IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Label Text="📷" FontSize="42"/>
                            <Label Text="Добавить фото" FontSize="12"/>

                        </VerticalStackLayout>

                        <Button
                            Command="{Binding PickImageCommand}"
                            BackgroundColor="Transparent"/>

                    </Grid>

                </Border>

                <!-- ВЫБОР РАСТЕНИЯ -->
                <VerticalStackLayout Spacing="6">

                    <Label
                        Text="Ваше растение"
                        FontSize="12"
                        TextColor="#777"/>

                    <Border
                        Stroke="#E0E0E0"
                        StrokeShape="RoundRectangle 12"
                        Padding="10">

                        <Picker
                            ItemsSource="{Binding MyPlants}"
                            ItemDisplayBinding="{Binding CustomName}"
                            SelectedItem="{Binding SelectedPlant}" />

                    </Border>

                </VerticalStackLayout>

                <!-- ОПИСАНИЕ -->
                <VerticalStackLayout Spacing="6">

                    <Entry
                        Placeholder="Что хотите получить?"
                        Text="{Binding DesiredText}"
                        BackgroundColor="Transparent"/>
 
                </VerticalStackLayout>

                <!-- BUTTON -->
                <Button
                    Text="Создать оффер"
                    Command="{Binding CreateCommand}"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="14"
                    HeightRequest="50"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</toolkit:Popup>