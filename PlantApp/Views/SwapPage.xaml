<ContentPage
    x:Class="PlantApp.Views.SwapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:data="clr-namespace:PlantApp.Data"
    xmlns:viewmodels="clr-namespace:PlantApp.ViewModels"
    x:DataType="viewmodels:SwapPageViewModel"
    BackgroundColor="White">

    <VerticalStackLayout Padding="20">

        <Label 
            Text="TEST SWAP PAGE"
            FontSize="24"
            TextColor="Black" />

        <Label 
            Text="{Binding Offers.Count}"
            FontSize="18"
            TextColor="Red" />

        <CollectionView ItemsSource="{Binding Offers}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="data:SwapOffer">

                    <VerticalStackLayout Padding="10" BackgroundColor="#EEEEEE" Margin="0,0,0,10">

                        <Label Text="{Binding Id}" FontSize="18"/>
                        <Label Text="{Binding OwnerName}" FontSize="16"/>
                        <Label Text="{Binding DesiredPlantDescription}" FontSize="14"/>

                    </VerticalStackLayout>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>