<ContentPage
    x:Class="PlantApp.Views.SwapPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:PlantApp.ViewModels"
    xmlns:converters="clr-namespace:PlantApp.Converters"
    xmlns:data="clr-namespace:PlantApp.Data" 
    x:DataType="viewmodels:SwapPageViewModel"    
    BackgroundColor="#F0EEE9">


    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <VerticalStackLayout Padding="16" Spacing="16">

            <Label
                Text="Обмен растениями"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="#1E1E1E" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                <Border BackgroundColor="#2E7D32" StrokeShape="RoundRectangle 25">
                    <Label Text="Все предложения"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Padding="12"/>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeShape="RoundRectangle 25">

                    <Label Text="Мои предложения"
                           TextColor="#2E7D32"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Padding="12"/>
                </Border>

            </Grid>

        </VerticalStackLayout>

        <!-- CONTENT -->
        <Grid Grid.Row="1">

            <!-- СПИСОК -->
            <CollectionView
                ItemsSource="{Binding Offers}"
                SelectionMode="None"
                RemainingItemsThreshold="5"
                RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                ZIndex="10">


                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="data:SwapOffer">

                        <Border
                            BackgroundColor="White"
                            Stroke="#E5E5E5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 15"
                            Padding="10"
                            Margin="10,0,10,10">

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                                <!-- IMAGE -->
                                <Border StrokeShape="RoundRectangle 15">
                                    <Image
                                        Source="{Binding ImageUrl, Converter={StaticResource ImagePathConverter}}"
                                        Aspect="AspectFill"/>
                                </Border>

                                <!-- CONTENT -->
                                <VerticalStackLayout Grid.Column="1" Spacing="6">

                                    <Label
                                        Text="{Binding Plant.CustomName, TargetNullValue='Без названия'}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="#1E1E1E"/>

                                    <Image
                                        Source="{Binding OwnerProfile, Converter={StaticResource AvatarHelper}}"
                                        HeightRequest="20"
                                        WidthRequest="20"/>

                                    <Label
                                        Text="{Binding Plant.Plant.NamePlant}"
                                        FontSize="12"
                                        TextColor="#777"/>

                                    <Label
                                        Text="{Binding OwnerName}"
                                        FontSize="12"
                                        TextColor="#777"/>

                                    <Label
                                        Text="{Binding DesiredPlantDescription}"
                                        FontSize="12"
                                        TextColor="#555"/>

                                    <Button
                                        Text="Предложить обмен"
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SendRequestCommand}"
                                        BackgroundColor="#2E7D32"
                                        TextColor="White"
                                        CornerRadius="12"
                                        HeightRequest="40"/>

                                </VerticalStackLayout>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <!-- SKELETON OVERLAY -->
            <Grid
                IsVisible="{Binding IsLoading}"
                BackgroundColor="#80000000"
                InputTransparent="False">

                <ActivityIndicator
                    IsRunning="True"
                    VerticalOptions="Center"
                    HorizontalOptions="Center" />

            </Grid>
        </Grid>

        <!-- BUTTONS -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="End" Padding="16" Spacing="10">


            <Button
                Text="Добавить свое"
                Command="{Binding OpenCreateOfferPopupCommand}"
                BackgroundColor="#2E7D32"
                TextColor="White"
                CornerRadius="20"/>


            <Button
                Text="Показать все"
                Command="{Binding ShowAllCommand}"
                BackgroundColor="#2E7D32"
                TextColor="White"
                CornerRadius="20"/>

            <Button
                Text="Загрузить еще"
                Command="{Binding LoadMoreCommand}"
                BackgroundColor="#EEEEEE"
                TextColor="Black"
                CornerRadius="20"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>