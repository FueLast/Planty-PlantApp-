<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PlantApp"
             xmlns:helpers="clr-namespace:PlantApp.Helpers"
             xmlns:converters="clr-namespace:PlantApp.Converters"
             x:Class="PlantApp.App">
    <Application.Resources>
        <ResourceDictionary>

            <helpers:AvatarHelper x:Key="AvatarHelper"/>

            <helpers:LastSeenHelper x:Key="LastSeenHelper"/>

            <helpers:ExpandTextHelper x:Key="ExpandTextHelper"/>

            <helpers:InverseBoolHelper x:Key="InverseBoolHelper"/>

            <converters:ImagePathConverter x:Key="ImagePathConverter"/>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
